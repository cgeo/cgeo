<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical">

	<include android:id="@+id/actionbar" layout="@layout/actionbar_popup" />

    <Spinner
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/dialogSpinner"
        android:padding="8dp" />

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@drawable/border_active"
		android:layout_margin="8dp"
		android:orientation="vertical"
		android:padding="8dp">

		<com.google.android.material.textfield.TextInputLayout android:id="@+id/latitudeFrame" style="@style/textinput_edittext_singleline">
			<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/latitude"
				style="@style/textinput_embedded_singleline"
				android:inputType="textNoSuggestions"
				android:hint="@string/latitude" />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout android:id="@+id/longitudeFrame" style="@style/textinput_edittext_singleline">
			<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/longitude"
				style="@style/textinput_embedded_singleline"
				android:inputType="textNoSuggestions"
				android:hint="@string/longitude" />
		</com.google.android.material.textfield.TextInputLayout>

		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/thirdCoordinateFrame"
			style="@style/textinput_edittext_singleline">
			<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/thirdCoordinate"
				style="@style/textinput_embedded_singleline"
				android:hint="@string/coord_input_northing"
				android:inputType="textNoSuggestions" />
		</com.google.android.material.textfield.TextInputLayout>

		<LinearLayout
			android:id="@+id/configurableLatitude"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_marginRight="8dp">

				<Button
					android:id="@+id/hemisphereLatitude"
					style="@style/button_letter"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textSize="@dimen/textSize_inputCoords"
					android:layout_weight="1" />

				<EditText
					android:id="@+id/editTextLatDegrees"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:inputType="number"
					android:selectAllOnFocus="true"
					android:hint="@string/cc_hint_degrees"
					android:gravity="right"
					android:maxLength = "2"
					android:layout_weight="3"/>

				<TextView
					android:id="@+id/txtLatSymbol1"
					android:text="@string/hash_symbol"
					android:textSize="@dimen/textSize_inputCoords"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_weight= "0.5"
                    tools:ignore="HardcodedText"/>

				<EditText
					android:id="@+id/editTextLatMinutes"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:selectAllOnFocus="true"
					android:inputType="number"
					android:gravity="right"
					android:hint="@string/cc_hint_minutes"
					android:maxLength = "2"
					android:layout_weight="3"/>

				<TextView
					android:id="@+id/txtLatSymbol2"
					android:text="@string/hash_symbol"
					android:textSize="@dimen/textSize_inputCoords"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_weight= "0.5"
                    tools:ignore="HardcodedText"/>

				<EditText
					android:id="@+id/editTextLatSeconds"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:selectAllOnFocus="true"
					android:inputType="number"
					android:gravity="right"
					android:hint="@string/cc_hint_seconds"
					android:maxLength = "2"
					android:layout_weight="3"/>

				<TextView
					android:id="@+id/txtLatSymbol3"
					android:text="@string/hash_symbol"
					android:textSize="@dimen/textSize_inputCoords"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_weight= "0.5"
                    tools:ignore="HardcodedText"/>

				<EditText
					android:id="@+id/editTextLatFraction"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:selectAllOnFocus="true"
					android:inputType="number"
					android:hint="@string/cc_hint_fraction"
					android:layout_weight="4"
					android:maxLength = "5"
					android:gravity="left" />

				<TextView
					android:id="@+id/txtLatSymbol4"
					android:text="@string/hash_symbol"
					android:textSize="@dimen/textSize_inputCoords"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_weight= "0.5"
                    tools:ignore="HardcodedText"/>


		</LinearLayout>

		<LinearLayout
			android:id="@+id/configurableLongitude"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_marginRight="8dp">

					<Button
						android:id="@+id/hemisphereLongitude"
						style="@style/button_letter"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:textSize="@dimen/textSize_inputCoords"
						android:layout_weight="1" />

					<EditText
						android:id="@+id/editTextLonDegrees"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:inputType="number"
						android:selectAllOnFocus="true"
						android:hint="@string/cc_hint_degrees"
						android:gravity="right"
						android:maxLength = "3"
						android:layout_weight="3"/>

					<TextView
						android:id="@+id/txtLonSymbol1"
						android:text="@string/hash_symbol"
						android:textSize="@dimen/textSize_inputCoords"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_weight= "0.5"
                        tools:ignore="HardcodedText"/>

					<EditText
						android:id="@+id/editTextLonMinutes"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:inputType="number"
						android:hint="@string/cc_hint_minutes"
						android:selectAllOnFocus="true"
						android:gravity="right"
						android:maxLength = "2"
						android:layout_weight="3" />

					<TextView
						android:id="@+id/txtLonSymbol2"
						android:text="@string/hash_symbol"
						android:textSize="@dimen/textSize_inputCoords"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_weight= "0.5"
                        tools:ignore="HardcodedText"/>

					<EditText
						android:id="@+id/editTextLonSeconds"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:inputType="number"
						android:hint="@string/cc_hint_seconds"
						android:selectAllOnFocus="true"
						android:gravity="right"
						android:maxLength = "2"
						android:layout_weight="3" />

					<TextView
						android:id="@+id/txtLonSymbol3"
						android:text="@string/hash_symbol"
						android:textSize="@dimen/textSize_inputCoords"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_weight= "0.5"
                        tools:ignore="HardcodedText"/>

					<EditText
						android:id="@+id/editTextLonFraction"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:inputType="number"
						android:hint="@string/cc_hint_fraction"
						android:selectAllOnFocus="true"
						android:gravity="left"
						android:maxLength = "5"
						android:layout_weight="4" />

					<TextView
						android:id="@+id/txtLonSymbol4"
						android:text="@string/hash_symbol"
						android:textSize="@dimen/textSize_inputCoords"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_weight= "0.5"
                        tools:ignore="HardcodedText"/>

			</LinearLayout>

	</LinearLayout>

	    <Button
            android:id="@+id/current"
            style="@style/button_full"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/waypoint_my_coordinates" />

		<RelativeLayout
			android:id="@+id/quickMapTargetButton"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginHorizontal="8dp"
			android:layout_marginTop="4dp"
			android:layout_marginBottom="8dp"
			android:background="@drawable/border_active"
			android:clickable="true"
			android:focusable="true"
			android:padding="8dp"
			android:visibility="gone">

			<TextView
				android:id="@+id/quickMapDistanceDirection"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_alignParentRight="true"
				android:layout_centerVertical="true"
				android:maxLines="1"
				android:textColor="@color/colorText_listsSecondary"
				android:textSize="@dimen/textSize_listsSecondary"
				tools:text="12.4 km NW" />

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_toLeftOf="@id/quickMapDistanceDirection"
				android:orientation="vertical"
				android:paddingRight="8dp">

				<TextView
					android:id="@+id/quickMapCoordinates"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:maxLines="2"
					android:textColor="@color/colorText_listsPrimary"
					android:textSize="@dimen/textSize_listsPrimary"
					tools:text="N 50° 08.030 E 008° 40.982" />

				<TextView
					android:id="@+id/quickMapCountry"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:maxLines="1"
					android:textColor="@color/colorText_listsSecondary"
					android:textSize="@dimen/textSize_listsSecondary"
					tools:text="Duitsland" />

			</LinearLayout>

		</RelativeLayout>

		<Button
			android:id="@+id/cache"
			style="@style/button_full"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:text="@string/waypoint_cache_coordinates" />

		<Button
			android:id="@+id/calculate"
			style="@style/button_full"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			app:icon="@drawable/ic_menu_variable"
			android:text="@string/waypoint_calculated_coordinates_global" />

        <Button
            android:id="@+id/clipboard"
            style="@style/button_full"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:text="@string/from_clipboard" />

		<Button
			android:id="@+id/clear"
			style="@style/button_full"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:text="@string/waypoint_clear_coordinates" />

</LinearLayout>
